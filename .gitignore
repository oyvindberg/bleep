target
.idea
.DS_Store
*.metals
.bsp
/.bleep
/.bloop
/project/.bloop
# bleep workspaces under docs-snippets-from-tests/ leak runtime state into the source tree
# when a developer runs `bleep` directly inside one; the docs-snippet ITs themselves use a
# tmpdir so this only catches manual runs. The fixtures' actual contents (bleep.yaml + src/)
# are git-tracked; .bleep/ and build/ are not.
docs-snippets-from-tests/*/.bleep/
docs-snippets-from-tests/*/build/
sbt-build
.vscode
bleep-cli.sh
test-project
reports
# TestNG writes its HTML report to ./test-output relative to the working directory, and
# ForkedTestRunnerFrameworkTest really does run TestNG (that is the thing under test), so a
# full `bleep test` leaves it in the repo root.
/test-output
.claude/